# 환경변수 / 시크릿
.env
.env.*
!.env.example

# 의존성
node_modules/
__pycache__/
*.pyc
venv/
.venv/

# 빌드 산출물
dist/
build/
.next/
out/

# 로그 / 임시
*.log
.DS_Store

# 로컬 도구 상태 (bkit)
.bkit/

# 로컬 도구 상태 (Claude Code) — 개인 설정/락 파일
.claude/

# 디자인 시안 미리보기 (참고용, 코드 아님)
mock/

# analyzer 런타임 상태 — history/backtest/calibration만 추적, intraday 등 임시파일 제외
analyzer/state/*
!analyzer/state/history/
!analyzer/state/history/*.json
!analyzer/state/backtest.json
!analyzer/state/calibration.json
analyzer/state/intraday_*.json
analyzer/out/
